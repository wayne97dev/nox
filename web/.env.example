# WalletConnect Cloud project id — https://cloud.reown.com
NEXT_PUBLIC_WC_PROJECT_ID=

# Chain config (8453 = Base mainnet, 84532 = Base Sepolia, 31337 = local Anvil)
NEXT_PUBLIC_CHAIN_ID=84532

# Dedicated RPC for the dApp's reads + stealth log scanning (Alchemy/Infura/etc).
# Strongly recommended — the public RPC will rate-limit the /stealth/receive scan.
# e.g. https://base-mainnet.g.alchemy.com/v2/YOUR_KEY
NEXT_PUBLIC_RPC_URL=

# Deployed contract addresses (fill after `forge script Deploy.s.sol --broadcast`)
NEXT_PUBLIC_NOX_TOKEN=
NEXT_PUBLIC_NOX_GENESIS=
NEXT_PUBLIC_NOX_HOOK=
NEXT_PUBLIC_STEALTH_REGISTRY=
NEXT_PUBLIC_STEALTH_ANNOUNCER=
NEXT_PUBLIC_NOX_STEALTH_SENDER=
NEXT_PUBLIC_STEALTH_MINING=

# Uniswap v4 infra on the target chain (for the /stats page)
# PoolManager + StateView — see https://docs.uniswap.org/contracts/v4/deployments
NEXT_PUBLIC_POOL_MANAGER=
NEXT_PUBLIC_STATE_VIEW=
